# Django settings
SECRET_KEY=your-secret-key-replace-me-in-production
DEBUG=1
DATABASE_URL=postgres://postgres:postgres@db:5432/postgres
ALLOWED_HOSTS=localhost,127.0.0.1

# Django superuser (for automatic creation)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=changeme

# Wagtail settings
WAGTAILADMIN_BASE_URL=http://localhost:8000

# Email settings (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@benniewilliams.com

# External integrations
GUMROAD_URL=https://gumroad.com/l/placeholder
YOUTUBE_API_KEY=

# Coolify webhook
COOLIFY_WEBHOOK_URL=

# AWS S3 settings (optional - uncomment to enable)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=
# AWS_S3_OBJECT_PARAMETERS={'CacheControl': 'max-age=86400'}
# USE_S3=False

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
PLAUSIBLE_DOMAIN=

# Security settings for production
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0